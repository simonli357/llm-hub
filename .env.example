WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_PASSWORD=replace-with-a-long-random-password
WEBUI_SECRET_KEY=replace-with-openssl-rand-hex-32

LITELLM_MASTER_KEY=sk-litellm-replace-with-a-long-random-key
POSTGRES_PASSWORD=replace-with-a-long-random-password

PUBLIC_WEBUI_URL=http://localhost:8090

# Optional helper defaults for scripts/litellm-key.
LITELLM_ADMIN_URL=http://127.0.0.1:4010
LLM_HUB_BASE_URL=http://127.0.0.1:8090

# Open WebUI file-context patch default: full-inject small text/code files.
SMALL_FILE_FULL_CONTEXT_MAX_BYTES=131072

# Local SearXNG-backed Open WebUI web search.
SEARXNG_QUERY_URL=http://127.0.0.1:8082/search
